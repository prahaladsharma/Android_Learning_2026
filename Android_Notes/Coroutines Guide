        .map { entities -> entities.map { it.toDomain() } }
        .flowOn(ioDispatcher)

    suspend fun refreshArticles(): Result<Unit> = withContext(ioDispatcher) {
        runCatching {
            val response = api.getTopHeadlines()
            dao.deleteAll()
            dao.insertAll(response.articles.map { it.toEntity() })
        }
    }
}
