### Measuring Sequential vs Parallel

```kotlin
import kotlinx.coroutines.*
import kotlin.system.measureTimeMillis

suspend fun sequential() {
    val time = measureTimeMillis {
        val a = fetchDataA() // 1000ms
        val b = fetchDataB() // 1000ms
        println("$a, $b")
    }
    println("Sequential: ${time}ms") // ~2000ms
}

suspend fun parallel() = coroutineScope {
    val time = measureTimeMillis {
        val a = async { fetchDataA() } // 1000ms
        val b = async { fetchDataB() } // 1000ms — starts immediately
        println("${a.await()}, ${b.await()}")
    }
    println("Parallel: ${time}ms") // ~1000ms
}

suspend fun fetchDataA() = withContext(Dispatchers.IO) { delay(1000L); "A" }
suspend fun fetchDataB() = withContext(Dispatchers.IO) { delay(1000L); "B" }
```

