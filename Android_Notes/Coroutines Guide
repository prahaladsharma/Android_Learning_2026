### Fragment — Best Practices

```kotlin
class ProfileFragment : Fragment(R.layout.fragment_profile) {

    private val viewModel: ProfileViewModel by viewModels()
    private var _binding: FragmentProfileBinding? = null
    private val binding get() = _binding!!

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        _binding = FragmentProfileBinding.bind(view)

        setupObservers()
        setupActions()
    }

    private fun setupObservers() {
        // Use viewLifecycleOwner, NOT 'this', to avoid memory leaks
        viewLifecycleOwner.lifecycleScope.launch {
            viewLifecycleOwner.repeatOnLifecycle(Lifecycle.State.STARTED) {
                viewModel.profile.collect { profile ->
                    binding.nameText.text = profile?.name ?: ""
                }
            }
        }
    }

    private fun setupActions() {
        binding.editButton.setOnClickListener {
            // Short one-off coroutine for click handling
            viewLifecycleOwner.lifecycleScope.launch {
                val result = viewModel.updateProfile(/* ... */)
                if (result.isSuccess) showSnackbar("Profile updated!")
            }
        }
    }

    override fun onDestroyView() {
        super.onDestroyView()
        _binding = null // Prevent memory leaks
    }
}
