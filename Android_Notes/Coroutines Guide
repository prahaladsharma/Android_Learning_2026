## 5. suspend Functions

### What is a `suspend` Function?

A `suspend` function can **pause execution** and **resume later** without blocking the thread. It can only be called from another `suspend` function or a coroutine builder.

```kotlin
// suspend keyword marks this function as pauseable
suspend fun fetchData(): String {
    delay(1000L) // Non-blocking pause
    return "Data loaded"
}

// Can only call fetchData() from:
// 1. Another suspend function
// 2. A coroutine builder (launch, async, etc.)
suspend fun processData() {
    val data = fetchData() // ✅ OK — inside suspend function
    println(data)
}

fun regularFunction() {
    // fetchData() // ❌ ERROR — cannot call suspend from regular function
    lifecycleScope.launch {
        fetchData() // ✅ OK — inside coroutine
    }
}
```

### Step-by-Step: Creating a suspend Function

```kotlin
// Step 1: Add the suspend modifier
suspend fun getUserFromDb(id: Int): User {

    // Step 2: Use withContext to switch to the right thread
    return withContext(Dispatchers.IO) {

        // Step 3: Do your blocking work here
        val cursor = database.query("SELECT * FROM users WHERE id = $id")
        cursor.use {
            User(
                id   = it.getInt(0),
                name = it.getString(1)
            )
        }
    }
}
```

### Suspend Function with Callback Conversion

```kotlin
import kotlinx.coroutines.*
import kotlin.coroutines.*

// Old callback-based API
interface LocationCallback {
    fun onLocationReceived(lat: Double, lng: Double)
    fun onError(error: String)
}

// Convert to suspend using suspendCoroutine
suspend fun getCurrentLocation(): Pair<Double, Double> {
    return suspendCoroutine { continuation ->
        locationManager.getLocation(object : LocationCallback {
            override fun onLocationReceived(lat: Double, lng: Double) {
                continuation.resume(Pair(lat, lng)) // Resume with result
            }
            override fun onError(error: String) {
                continuation.resumeWithException(Exception(error)) // Resume with error
            }
        })
    }
}

// Usage
suspend fun showLocation() {
    try {
        val (lat, lng) = getCurrentLocation()
        println("Location: $lat, $lng")
    } catch (e: Exception) {
        println("Error: ${e.message}")
    }
}
```

### suspendCancellableCoroutine (Preferred for Cancellation)

```kotlin
import kotlinx.coroutines.*

suspend fun fetchImage(url: String): Bitmap {
    return suspendCancellableCoroutine { continuation ->
        val call = imageLoader.load(url) { bitmap ->
            continuation.resume(bitmap)
        }

        // Called when the coroutine is cancelled
        continuation.invokeOnCancellation {
            call.cancel() // Clean up the underlying operation
        }
    }
}
```

