## 22. Parallel Decomposition

### Running Tasks in Parallel with `async`

```kotlin
import kotlinx.coroutines.*

data class UserProfile(
    val user: User,
    val posts: List<Post>,
    val followers: List<User>
)

suspend fun loadUserProfile(userId: Int): UserProfile = coroutineScope {

    // All three start SIMULTANEOUSLY
    val userDeferred      = async(Dispatchers.IO) { api.getUser(userId) }
    val postsDeferred     = async(Dispatchers.IO) { api.getPosts(userId) }
    val followersDeferred = async(Dispatchers.IO) { api.getFollowers(userId) }

    // Await all results — total time = max(user, posts, followers) NOT sum
    UserProfile(
        user      = userDeferred.await(),
        posts     = postsDeferred.await(),
        followers = followersDeferred.await()
    )
}
```

### `awaitAll()` for Dynamic Lists

```kotlin
import kotlinx.coroutines.*

suspend fun loadMultipleUsers(ids: List<Int>): List<User> = coroutineScope {
    ids.map { id ->
        async(Dispatchers.IO) { api.getUser(id) }
    }.awaitAll() // Waits for all, throws if ANY fails
}

// More resilient version
suspend fun loadUsersResiliently(ids: List<Int>): List<Result<User>> = coroutineScope {
    ids.map { id ->
        async(Dispatchers.IO) {
            runCatching { api.getUser(id) }
        }
    }.awaitAll()
}
