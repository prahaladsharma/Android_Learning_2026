### 19.5 Fan-In (Many Producers, One Consumer)

```kotlin
import kotlinx.coroutines.*
import kotlinx.coroutines.channels.*

fun main() = runBlocking {
    val mergedChannel = Channel<String>(10)

    // Multiple producers
    launch { mergedChannel.send("From Producer 1"); delay(100); mergedChannel.send("From Producer 1 again") }
    launch { mergedChannel.send("From Producer 2"); delay(200); mergedChannel.send("From Producer 2 again") }

    // One consumer reads from both
