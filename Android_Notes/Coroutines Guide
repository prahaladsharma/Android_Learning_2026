## 20. Coroutine Context & CoroutineScope

### CoroutineContext = Dispatcher + Job + Name + ExceptionHandler

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // Inspect the current context
    println("Current context: $coroutineContext")
    println("Current Job: ${coroutineContext[Job]}")
    println("Current Dispatcher: ${coroutineContext[ContinuationInterceptor]}")

    // Create a scope with a custom context
    val myContext = Dispatchers.IO +
            CoroutineName("MyCoroutine") +
            CoroutineExceptionHandler { _, e -> println("Error: $e") }

    val scope = CoroutineScope(myContext)

    scope.launch {
        println("Running in: ${coroutineContext[CoroutineName]}")
        // Prints: Running in: CoroutineName(MyCoroutine)
    }.join()

    scope.cancel()
}
