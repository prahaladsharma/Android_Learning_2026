## 8. Job & Deferred

### Job — Coroutine Handle

A `Job` is a handle to a running coroutine. You can use it to monitor state, wait for completion, or cancel it.

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {
    val job = launch {
        repeat(5) { i ->
            delay(500L)
            println("Working... step $i")
        }
    }

    // Job states
    println("isActive:    ${job.isActive}")    // true
    println("isCompleted: ${job.isCompleted}") // false
    println("isCancelled: ${job.isCancelled}") // false

    delay(1200L)
    job.cancel()  // Cancel after 1.2 seconds (runs steps 0, 1, 2)
    job.join()    // Wait for cancellation to complete

    println("isActive:    ${job.isActive}")    // false
    println("isCompleted: ${job.isCompleted}") // false
    println("isCancelled: ${job.isCancelled}") // true
}
```

### Deferred — Job with a Result

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    val deferred: Deferred<Int> = async {
        delay(1000L)
        42 // The result
    }

    println("Waiting for result...")
    val result = deferred.await() // Suspends until ready
    println("Result: $result")   // Result: 42

    // You can also cancel a Deferred
    val cancelledDeferred = async {
        delay(5000L)
        "never"
    }
    cancelledDeferred.cancel()
    try {
        cancelledDeferred.await()
    } catch (e: CancellationException) {
        println("Deferred was cancelled")
    }
}
```

### SupervisorJob — Isolate Child Failures

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // Without SupervisorJob — one child fails = all siblings cancelled
    val regularJob = Job()
    val regularScope = CoroutineScope(regularJob)

    // With SupervisorJob — one child fails = siblings continue
    val supervisorJob = SupervisorJob()
    val supervisorScope = CoroutineScope(supervisorJob)

    supervisorScope.launch {
        delay(100)
        throw RuntimeException("Child 1 failed!")
    }

    supervisorScope.launch {
        delay(300)
        println("Child 2 still running!") // ✅ Still executes
    }

    delay(500)
    supervisorScope.cancel()
}
```

