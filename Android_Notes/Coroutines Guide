## 11. Exception Handling

### 11.1 try/catch in Coroutines

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {
    launch {
        try {
            val result = riskyOperation()
            println("Success: $result")
        } catch (e: HttpException) {
            println("HTTP Error: ${e.code()}")
        } catch (e: IOException) {
            println("Network Error: ${e.message}")
        } catch (e: Exception) {
            println("Unknown Error: ${e.message}")
        }
    }
}

suspend fun riskyOperation(): String {
    delay(100)
    throw IOException("Connection refused")
}
```

### 11.2 `CoroutineExceptionHandler`

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // Global exception handler for uncaught coroutine exceptions
    val handler = CoroutineExceptionHandler { context, exception ->
        println("Caught in handler: $exception")
        // Log to Firebase Crashlytics etc.
    }

    // Handler must be attached to root coroutine scope
    val scope = CoroutineScope(SupervisorJob() + handler)

    scope.launch {
        throw RuntimeException("Something went wrong!")
    }

    scope.launch {
        delay(200)
        println("This still runs") // SupervisorJob isolates the failure
    }

    delay(500)
    scope.cancel()
}
```

### 11.3 Exception Propagation: `launch` vs `async`

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // launch — exception thrown immediately (propagates to parent)
    val launchJob = launch {
        try {
            throw RuntimeException("launch exception")
        } catch (e: Exception) {
            println("launch caught: ${e.message}")
        }
    }

    // async — exception deferred until .await() is called
    val asyncDeferred = async {
        throw RuntimeException("async exception")
        "never reached"
    }

    try {
        asyncDeferred.await() // Exception thrown HERE
    } catch (e: RuntimeException) {
        println("async caught: ${e.message}")
    }

    launchJob.join()
}
```

