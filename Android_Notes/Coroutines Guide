## 25. Repository Pattern with Coroutines

### Full Repository with Offline-First Strategy

```kotlin
class NewsRepository @Inject constructor(
    private val api: NewsApiService,
    private val dao: NewsDao,
    @IoDispatcher private val ioDispatcher: CoroutineDispatcher
) {

    // Offline-first: emit cached data first, then refresh from network
    fun getNewsArticles(): Flow<Resource<List<Article>>> = flow {
        // 1. Emit cached data immediately
        val cachedArticles = dao.getAllArticles().first()
        if (cachedArticles.isNotEmpty()) {
            emit(Resource.Success(cachedArticles.map { it.toDomain() }))
        } else {
            emit(Resource.Loading)
        }

        // 2. Fetch fresh data from network
        try {
            val freshArticles = api.getArticles()
            dao.deleteAll()
            dao.insertAll(freshArticles.map { it.toEntity() })
            // 3. Room will automatically emit the new data via Flow
        } catch (e: Exception) {
            if (cachedArticles.isEmpty()) {
                emit(Resource.Error("No internet connection and no cached data"))
            }
            // If we have cache, silently fail (user already sees data)
        }
    }
    .flowOn(ioDispatcher)
    .catch { e -> emit(Resource.Error(e.message ?: "Unknown error")) }

    // Combine local DB flow with periodic refresh
    fun getNewsWithAutoRefresh(): Flow<List<Article>> {
        return dao.getAllArticlesFlow()
            .map { entities -> entities.map { it.toDomain() } }
            .onStart { refreshNews() } // Refresh when collection starts
            .flowOn(ioDispatcher)
    }

    private suspend fun refreshNews() {
        try {
            val articles = api.getArticles()
            dao.deleteAll()
            dao.insertAll(articles.map { it.toEntity() })
        } catch (e: Exception) {
            // Silently fail — cached data will still be shown
        }
    }
}
```

