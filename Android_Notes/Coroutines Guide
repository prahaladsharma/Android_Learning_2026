## 14. Kotlin Flow

A **Flow** is a cold, asynchronous stream of data. It only runs when collected.

### 14.1 Creating a Flow

```kotlin
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.*

// Simple flow
val simpleFlow: Flow<Int> = flow {
    println("Flow started")       // runs each time collected
    emit(1)
    delay(100)
    emit(2)
    delay(100)
    emit(3)
}

// flowOf — from fixed values
val fixedFlow: Flow<String> = flowOf("A", "B", "C")

// asFlow — from Iterable
val listFlow: Flow<Int> = listOf(1, 2, 3, 4, 5).asFlow()

// channelFlow — for concurrent emissions
val channelFlow = channelFlow {
    send(1)
    withContext(Dispatchers.IO) {
        send(2) // can emit from different coroutines
    }
}
```

### 14.2 Flow Operators

```kotlin
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.*

fun main() = runBlocking {
    flow {
        emit(1); emit(2); emit(3); emit(4); emit(5)
    }
    // Transformation operators
    .map       { it * 2 }           // [2, 4, 6, 8, 10]
    .filter    { it > 4 }           // [6, 8, 10]
    .take      (2)                  // [6, 8]

    // Side effects
    .onEach    { println("Item: $it") }
    .onStart   { println("Flow started") }
    .onCompletion { println("Flow completed") }

    // Collect the flow
    .collect   { println("Collected: $it") }
}
```

### 14.3 Terminal Operators

```kotlin
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.*

fun main() = runBlocking {
    val numbers = (1..5).asFlow()

    // collect — most common
    numbers.collect { println(it) }

    // collectLatest — cancels previous if new comes before it finishes
    numbers.collectLatest { value ->
        delay(100) // Slow processing
        println("Collected latest: $value") // Only last value may be printed
    }

    // toList / toSet
    val list = numbers.toList()  // [1, 2, 3, 4, 5]
    val set  = numbers.toSet()   // {1, 2, 3, 4, 5}

    // first / last
    val first = numbers.first()  // 1
    val last  = numbers.last()   // 5

    // single
    val single = flowOf(42).single() // 42 (throws if not exactly one)

    // reduce / fold
    val sum = numbers.reduce { acc, value -> acc + value }  // 15
    val sum2 = numbers.fold(100) { acc, value -> acc + value } // 115
}
```

### 14.4 Advanced Flow Operators

```kotlin
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.*

fun main() = runBlocking {

    // flatMapConcat — sequential inner flows
    (1..3).asFlow()
        .flatMapConcat { value ->
            flow { emit("$value-A"); emit("$value-B") }
        }
        .collect { println(it) }
    // 1-A, 1-B, 2-A, 2-B, 3-A, 3-B

    // flatMapMerge — concurrent inner flows
    (1..3).asFlow()
        .flatMapMerge { value ->
            flow {
                delay((4 - value) * 100L) // Different delays
                emit(value)
            }
        }
        .collect { println(it) }
    // 3, 2, 1 (order not guaranteed)

    // flatMapLatest — cancel previous if new arrives
    (1..3).asFlow()
        .onEach { delay(100) }
        .flatMapLatest { value ->
            flow {
                emit("$value: start")
                delay(300) // Takes longer than outer delay
                emit("$value: end") // Often cancelled
            }
        }
        .collect { println(it) }

    // zip — combine two flows element by element
    val names  = flowOf("Alice", "Bob", "Charlie")
    val scores = flowOf(95, 87, 92)
    names.zip(scores) { name, score -> "$name: $score" }
        .collect { println(it) }
    // Alice: 95, Bob: 87, Charlie: 92

    // combine — emit whenever ANY flow emits
    val flow1 = MutableStateFlow(0)
    val flow2 = MutableStateFlow(0)
    combine(flow1, flow2) { a, b -> "a=$a, b=$b" }
        .take(3)
        .collect { println(it) }
}
```

### 14.5 Flow Exception Handling

```kotlin
import kotlinx.coroutines.flow.*
import kotlinx.coroutines.*

fun riskyFlow(): Flow<Int> = flow {
    emit(1)
    emit(2)
    throw IOException("Network error!")
    emit(3) // Never reached
}

fun main() = runBlocking {

    // catch operator — handles exceptions in upstream flow
    riskyFlow()
        .catch { e -> emit(-1) } // Emit fallback value on error
        .collect { println(it) } // 1, 2, -1

    // retry — retry on failure
    riskyFlow()
        .retry(3) { e -> e is IOException } // Retry up to 3 times for IOException
        .catch { e -> println("Final failure: $e") }
        .collect { println(it) }

    // retryWhen — retry with custom logic
    riskyFlow()
        .retryWhen { cause, attempt ->
            if (cause is IOException && attempt < 3) {
                delay(1000L * attempt) // Exponential backoff
                true // Retry
            } else {
                false // Don't retry
            }
        }
        .catch { e -> println("Gave up: $e") }
        .collect { println(it) }
}
```

