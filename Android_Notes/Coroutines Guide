### 19.4 Fan-Out (One Producer, Many Consumers)

```kotlin
import kotlinx.coroutines.*
import kotlinx.coroutines.channels.*

fun main() = runBlocking {
    val channel = Channel<Int>(10)

    // One producer
    launch {
        for (i in 1..10) {
            channel.send(i)
        }
        channel.close()
    }

    // Multiple consumers
    repeat(3) { consumerId ->
        launch {
            for (item in channel) {
                println("Consumer $consumerId got: $item")
                delay(100)
            }
        }
    }

    delay(2000)
}
