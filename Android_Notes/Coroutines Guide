## 27. Common Anti-Patterns & Pitfalls

### ❌ Pitfall 1: Blocking the Main Thread

```kotlin
// ❌ BAD — Thread.sleep blocks the UI thread!
fun loadData() {
    Thread.sleep(3000)
    textView.text = "Done"
}

// ✅ GOOD
fun loadData() {
    lifecycleScope.launch {
        delay(3000)           // Non-blocking
        textView.text = "Done"
    }
}
```

### ❌ Pitfall 2: Using GlobalScope

```kotlin
// ❌ BAD — coroutine lives forever, even after screen is gone
fun load() {
    GlobalScope.launch {
        val data = fetchData()
        textView.text = data // textView may be destroyed!
    }
}

// ✅ GOOD — cancelled with ViewModel lifecycle
fun load() {
    viewModelScope.launch {
        val data = fetchData()
        _data.value = data
    }
}
```

### ❌ Pitfall 3: Swallowing CancellationException

```kotlin
// ❌ BAD — CancellationException is caught and swallowed
launch {
    try {
        delay(1000)
    } catch (e: Exception) { // catches ALL exceptions including CancellationException
        Log.e("TAG", "Error")
    }
}

// ✅ GOOD — only catch what you can handle
launch {
    try {
        delay(1000)
    } catch (e: IOException) {
        Log.e("TAG", "Network error")
    }
    // Or: catch Exception but re-throw CancellationException
    try {
        delay(1000)
    } catch (e: Exception) {
        if (e is CancellationException) throw e // Re-throw!
        Log.e("TAG", "Other error")
    }
}
```

### ❌ Pitfall 4: launch inside launch (Escaping Structured Concurrency)

```kotlin
// ❌ BAD — inner launch escapes the outer scope
suspend fun loadData() = coroutineScope {
    launch {
        launch(GlobalScope.coroutineContext) { // ← Escapes structured concurrency!
            fetchData()
        }
    }
}

// ✅ GOOD — keep coroutines within their scope
suspend fun loadData() = coroutineScope {
    launch {
        launch {
            fetchData() // ← properly nested
        }
    }
}
```

### ❌ Pitfall 5: Not Switching to IO Dispatcher for Blocking Calls

```kotlin
// ❌ BAD — blocking IO on Dispatchers.Main freezes UI
class MyViewModel : ViewModel() {
    fun loadUser() {
        viewModelScope.launch { // Default: Dispatchers.Main
            val user = database.getUser(1) // ← Blocking call on Main!
            _user.value = user
        }
    }
}

// ✅ GOOD
class MyViewModel : ViewModel() {
    fun loadUser() {
        viewModelScope.launch {
            val user = withContext(Dispatchers.IO) { // ← Switch for blocking work
                database.getUser(1)
            }
            _user.value = user // ← Back on Main
        }
    }
}
```

### ❌ Pitfall 6: Collecting Flow in Fragment without repeatOnLifecycle

```kotlin
// ❌ BAD — continues collecting even when Fragment is in background
override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
    lifecycleScope.launch {
        viewModel.data.collect { render(it) } // Never stops!
    }
}

// ✅ GOOD — automatically pauses/resumes with lifecycle
override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
    viewLifecycleOwner.lifecycleScope.launch {
        viewLifecycleOwner.repeatOnLifecycle(Lifecycle.State.STARTED) {
            viewModel.data.collect { render(it) } // Pauses when STOPPED
        }
    }
}
```

### ❌ Pitfall 7: Making async Lazy by Accident

```kotlin
// ❌ This is SEQUENTIAL — awaits each one before starting next
val a = async { fetchA() }.await()
val b = async { fetchB() }.await()

// ✅ This is PARALLEL — starts both, then awaits
val deferredA = async { fetchA() }
val deferredB = async { fetchB() }
val a = deferredA.await()
val b = deferredB.await()
```

