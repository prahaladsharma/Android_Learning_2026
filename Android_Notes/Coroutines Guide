## 10. Cancellation & Timeouts

### 10.1 Cancellation Basics

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {
    val job = launch {
        repeat(10) { i ->
            // delay() is a cancellation checkpoint
            delay(300)
            println("Step $i")
        }
    }

    delay(1000)
    println("Cancelling...")
    job.cancelAndJoin() // cancel + wait
    println("Cancelled!")
}
```

### 10.2 Making Custom Code Cancellable

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {
    val job = launch(Dispatchers.Default) {
        // CPU-intensive loop — need manual cancellation checks
        var count = 0
        while (isActive) { // isActive = false when cancelled
            count++
            // Process item...
        }
        println("Loop ended. Processed $count items")
    }

    delay(1000)
    job.cancelAndJoin()
}
```

### 10.3 Using `yield()` for Cancellation Points

```kotlin
import kotlinx.coroutines.*

suspend fun heavyComputation() {
    repeat(1000) { i ->
        // Do heavy work...
        val result = i * i

        // yield() checks for cancellation AND lets other coroutines run
        yield()
    }
}
```

### 10.4 Handling `CancellationException`

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {
    val job = launch {
        try {
            delay(Long.MAX_VALUE)
        } catch (e: CancellationException) {
            println("Coroutine cancelled — cleaning up resources")
            // Do cleanup (close files, DB connections, etc.)
            throw e // ⚠️ ALWAYS re-throw CancellationException!
        } finally {
            // finally block always runs, even on cancellation
            println("Finally block — always runs")
        }
    }

    delay(500)
    job.cancel()
    job.join()
}
```

### 10.5 `withTimeout`

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // Throws TimeoutCancellationException if exceeds limit
    try {
        val result = withTimeout(2000L) {
            delay(3000L) // Takes longer than timeout
            "Result"
        }
        println(result)
    } catch (e: TimeoutCancellationException) {
        println("Timed out!")
    }

    // Returns null on timeout instead of throwing
    val result = withTimeoutOrNull(2000L) {
        delay(3000L)
        "Result"
    }
    println("Result: $result") // Result: null
}
```

### 10.6 Non-Cancellable Block (for Cleanup)

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {
    val job = launch {
        try {
            delay(Long.MAX_VALUE)
        } finally {
            // withContext(NonCancellable) ensures this runs even when cancelled
            withContext(NonCancellable) {
                println("Saving data before exit...")
                delay(500L) // Can use suspend functions here
                println("Data saved!")
            }
        }
    }

    delay(200)
    job.cancelAndJoin()
    println("Main completed")
}
```

