## 4. Coroutine Builders

Coroutine builders are functions that **start a new coroutine**.

### 4.1 `launch` — Fire and Forget

```kotlin
import kotlinx.coroutines.*

class MainActivity : AppCompatActivity() {

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        // launch returns a Job (no result value)
        val job = lifecycleScope.launch {
            delay(1000L)
            Log.d("Coroutine", "Hello from coroutine!")
        }

        // You can cancel it
        // job.cancel()
    }
}
```

### 4.2 `async` — Returns a Result

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // async returns Deferred<String>
    val deferred = async {
        delay(1000L)
        "Hello from async!"
    }

    // await() suspends until the result is ready
    val result: String = deferred.await()
    println(result) // Hello from async!
}
```

### 4.3 `runBlocking` — Blocks Current Thread (Testing Only)

```kotlin
import kotlinx.coroutines.*

// Use ONLY for main() functions or unit tests
// NEVER use in Android production code (blocks UI thread)
fun main() = runBlocking {
    println("Start")
    delay(1000L)
    println("End")
}
```

### 4.4 `withContext` — Switch Dispatcher, Return Result

```kotlin
import kotlinx.coroutines.*

suspend fun fetchUserName(): String {
    // Switch to IO thread, do work, return result
    return withContext(Dispatchers.IO) {
        delay(500L) // Simulate network
        "John Doe"
    }
    // Automatically returns to original dispatcher after the block
}

fun main() = runBlocking {
    val name = fetchUserName()
    println(name) // John Doe
}
```

### 4.5 `coroutineScope` — Child Scope Builder

```kotlin
import kotlinx.coroutines.*

suspend fun loadDashboard() = coroutineScope {
    // Creates a child scope
    // Suspends until ALL children complete
    val users  = async { fetchUsers() }
    val orders = async { fetchOrders() }

    // Both run in parallel
    println("Users: ${users.await()}, Orders: ${orders.await()}")
}

suspend fun fetchUsers()  = "UserList"
suspend fun fetchOrders() = "OrderList"
```

### 4.6 `supervisorScope` — Isolated Child Failures

```kotlin
import kotlinx.coroutines.*

suspend fun robustLoad() = supervisorScope {
    val job1 = launch {
        delay(100)
        throw RuntimeException("Job 1 failed!")
        // Failure does NOT cancel siblings
    }

    val job2 = launch {
        delay(200)
        println("Job 2 completed successfully") // Still runs!
    }

    job1.join()
    job2.join()
}
```

