## 7. Dispatchers

Dispatchers determine **which thread or thread pool** a coroutine runs on.

### Available Dispatchers

```kotlin
import kotlinx.coroutines.*

fun main() = runBlocking {

    // Dispatchers.Main — Android UI thread
    launch(Dispatchers.Main) {
        // ✅ Safe to update Views here
        textView.text = "Hello"
    }

    // Dispatchers.IO — Optimized for I/O (network, files, DB)
    // Thread pool size: max(64, numberOfCores)
    launch(Dispatchers.IO) {
        val data = File("data.txt").readText() // blocking I/O
        println("File content: $data")
    }

    // Dispatchers.Default — Optimized for CPU-intensive work
    // Thread pool size: numberOfCores (min 2)
    launch(Dispatchers.Default) {
        val result = (1..1_000_000).sum() // heavy computation
        println("Sum: $result")
    }

    // Dispatchers.Unconfined — Runs in caller's thread until first suspension
    // (Rarely used in Android)
    launch(Dispatchers.Unconfined) {
        println("Thread: ${Thread.currentThread().name}")
        delay(100)
        println("Thread after delay: ${Thread.currentThread().name}") // May be different!
    }
}
```

### Choosing the Right Dispatcher

```kotlin
class DataRepository(
    private val api: ApiService,
    private val dao: UserDao,
    private val context: Context
) {

    // Network call → Dispatchers.IO
    suspend fun fetchUserFromApi(id: Int): User = withContext(Dispatchers.IO) {
        api.getUser(id)
    }

    // Database call → Dispatchers.IO
    suspend fun getUserFromDb(id: Int): User = withContext(Dispatchers.IO) {
        dao.getUser(id)
    }

    // JSON parsing / Sorting → Dispatchers.Default
    suspend fun parseUsers(json: String): List<User> = withContext(Dispatchers.Default) {
        Gson().fromJson(json, Array<User>::class.java).toList()
    }

    // File read/write → Dispatchers.IO
    suspend fun saveToFile(data: String) = withContext(Dispatchers.IO) {
        val file = File(context.filesDir, "cache.txt")
        file.writeText(data)
    }
}
```

### Custom Dispatcher (Thread Pool)

```kotlin
import kotlinx.coroutines.*
import java.util.concurrent.Executors

// Create a custom thread pool dispatcher
val customDispatcher = Executors.newFixedThreadPool(4).asCoroutineDispatcher()

fun main() = runBlocking {
    launch(customDispatcher) {
        println("Running on custom thread pool")
    }
}

// Don't forget to shut it down when done
// customDispatcher.close()
```

