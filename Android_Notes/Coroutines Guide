        viewModelScope.launch {
            _isLoading.value = true
            try {
                val result = withContext(Dispatchers.IO) {
                    repository.getAllUsers()
                }
                _users.value = result
            } catch (e: Exception) {
                _errorMessage.emit(e.message ?: "Failed to load users")
            } finally {
                _isLoading.value = false
            }
        }
    }

    fun addUser(name: String, email: String) {
        viewModelScope.launch {
            try {
                val newUser = withContext(Dispatchers.IO) {
                    repository.createUser(name, email)
                }
                _users.value = _users.value + newUser
            } catch (e: Exception) {
                _errorMessage.emit(e.message ?: "Failed to add user")
            }
        }
    }

    fun deleteUser(userId: Int) {
        viewModelScope.launch {
            try {
                withContext(Dispatchers.IO) {
                    repository.deleteUser(userId)
                }
                _users.value = _users.value.filter { it.id != userId }
            } catch (e: Exception) {
                _errorMessage.emit("Failed to delete user")
            }
        }
    }
